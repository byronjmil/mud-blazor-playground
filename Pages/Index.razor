@page "/"

@inject IHttpService HttpService

@using ThreeDiamonds.Service
@using Newtonsoft.Json
@using Newtonsoft.Json.Linq
@using System
@using System.Globalization

<PageTitle>Three Diamonds</PageTitle>

<div style="text-align: center;">
    @if (currentPriceObject != null && currentBag != 0)
    {
        <MudGrid>
            <MudItem xs="12">
                <MudText Class="bitcoin">
                   ₿ @(currentBag / Math.Pow(10, 8))
                </MudText>
            </MudItem>
        </MudGrid>
        <MudGrid>
            <MudItem xs="12">
                <MudText Class="gold">
                    XAU @(
                        Math.Round(
                            ((currentBag / Math.Pow(10, 8)) * ConvertStringToDecimal(currentPriceObject["xau"]?.ToString())),
                            2
                        )
                    )
                </MudText>
            </MudItem>
        </MudGrid>
        <MudDivider></MudDivider>
        @foreach (var kvp in currencyToCountryCode)
        {
            @if (currentPriceObject[kvp.Key.ToLower()] != null)
            {
                <MudGrid>
                    <MudItem xs="12">
                        <MudText>@(
                            ToCurrency(
                                ((currentBag / Math.Pow(10, 8)) * ConvertStringToDecimal(currentPriceObject[kvp.Key.ToLower()]?.ToString())), kvp.Value
                            )
                        )
                        </MudText>
                    </MudItem>
                </MudGrid>
            }
        }
    }
</div>

<MudOverlay Visible="showLoadingOverlay" DarkBackground>
    <MudProgressCircular Color="Color.Default" Indeterminate />
</MudOverlay>

